{
  "expo": {
    "name": "ValuIQ",
    "slug": "valuiq-mobile",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#111009",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111009"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.valuiq.app",
      "infoPlist": {
        "NSCameraUsageDescription": "ValuIQ uses your camera to scan items and identify their resale value.",
        "NSPhotoLibraryUsageDescription": "ValuIQ accesses your photo library so you can scan items from saved photos.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "ValuIQ uses Face ID to keep your account secure and sign you in faster.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "valuiq"
            ]
          }
        ]
      },

      "jsEngine": "jsc"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111009"
      },
      "package": "com.valuiq.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker",
      "expo-local-authentication"
    ],
    "scheme": "valuiq",
    "extra": {
      "eas": {
        "projectId": "8f5ddfbb-4b97-497e-8249-71cdf1b6811c"
      }
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "newArchEnabled": false,
    "owner": "valuiq2"
  }
}
