{
  "expo": {
    "name": "ValuIQ",
    "slug": "valuiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#111009",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111009"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.valuiq.app",
      "infoPlist": {
        "NSCameraUsageDescription": "ValuIQ uses your camera to scan items and identify their resale value.",
        "NSPhotoLibraryUsageDescription": "ValuIQ accesses your photo library so you can scan items from saved photos.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "ValuIQ uses Face ID to keep your account secure and sign you in faster.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "valuiq"
            ]
          }
        ]
      },
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111009"
      },
      "package": "com.valuiq.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker"
    ],
    "scheme": "valuiq",
    "extra": {
      "eas": {
        "projectId": "bb177200-53bd-42d9-878d-91795b0af17a"
      }
    }
  }
}